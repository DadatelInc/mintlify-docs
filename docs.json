          "quickstart"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "name": "Community",
          "icon": "discord",
          "url": "https://discord.gg/Zec49GD6ps"
        },
        {
          "name": "Blog",
          "icon": "newspaper",
          "url": "https://blog.netisu.com"
        }
    ],
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "link here",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
