{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "layout": "topnav",
  "name": "Mintlify Starter Kit",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "topbar": {
    "style": "gradient"
  },
  "background": {
    "style": "grid"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
